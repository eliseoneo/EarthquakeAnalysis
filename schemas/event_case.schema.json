{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventCase",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "country",
    "time_window",
    "main_event",
    "doublet",
    "aftershocks",
    "felt_intensity",
    "urban_areas_affected",
    "structural_damage",
    "soil_type",
    "associated_faults",
    "weather_post_event",
    "landslide_instability",
    "population_density",
    "sources",
    "advanced_features",
    "compound_risk_model"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_name": { "type": "string" },
    "country": { "type": "string" },
    "time_window": {
      "type": "object",
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": { "type": "string" },
        "end_date": { "type": "string" }
      }
    },
    "main_event": {
      "type": "object",
      "required": ["magnitude_mw", "depth_km", "location"],
      "properties": {
        "magnitude_mw": { "type": "number" },
        "depth_km": { "type": "number" },
        "location": { "type": "string" }
      }
    },
    "doublet": {
      "type": "object",
      "required": ["present", "notes"],
      "properties": {
        "present": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "aftershocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "magnitude_mw", "depth_km", "location"],
        "properties": {
          "date": { "type": "string" },
          "magnitude_mw": { "type": "number" },
          "depth_km": { "type": "number" },
          "location": { "type": "string" }
        }
      }
    },
    "felt_intensity": { "type": "string" },
    "urban_areas_affected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "structural_damage": { "type": "string" },
    "soil_type": { "type": "string" },
    "associated_faults": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weather_post_event": { "type": "string" },
    "landslide_instability": { "type": "string" },
    "population_density": { "type": "string" },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "advanced_features": {
      "type": "object",
      "required": ["seismic", "geological_geotechnical", "climatic", "human_urban"],
      "properties": {
        "seismic": {
          "type": "object",
          "required": [
            "magnitude_mw",
            "depth_km",
            "focal_mechanism",
            "distance_to_fault_km",
            "estimated_slip_rate_mm_per_year",
            "pga_g",
            "pgv_cm_per_s",
            "mmi_intensity",
            "aftershock_count",
            "omori_decay_p",
            "gutenberg_richter_b_value",
            "local_seismic_density"
          ],
          "properties": {
            "magnitude_mw": { "type": "number" },
            "depth_km": { "type": "number" },
            "focal_mechanism": { "type": "string" },
            "distance_to_fault_km": { "type": "number" },
            "estimated_slip_rate_mm_per_year": { "type": "number" },
            "pga_g": { "type": ["number", "null"] },
            "pga_measurement_quality": {
              "type": "string",
              "enum": [
                "instrumented_strong_motion",
                "estimated_indirect",
                "unknown"
              ]
            },
            "pga_calibration_bias_warning": { "type": "string" },
            "pga_station_estimates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["location", "pga_g", "estimate_method", "source"],
                "properties": {
                  "location": { "type": "string" },
                  "pga_g": { "type": "number" },
                  "pga_g_min": { "type": "number" },
                  "pga_g_max": { "type": "number" },
                  "site_class": { "type": "string" },
                  "estimate_method": { "type": "string" },
                  "source": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            },
            "pgv_cm_per_s": { "type": ["number", "null"] },
            "mmi_intensity": { "type": "string" },
            "aftershock_count": { "type": "integer" },
            "omori_decay_p": { "type": "number" },
            "gutenberg_richter_b_value": { "type": "number" },
            "local_seismic_density": { "type": "string" }
          }
        },
        "geological_geotechnical": {
          "type": "object",
          "required": [
            "soil_type",
            "lithology",
            "vs30_m_per_s",
            "slope_degrees",
            "sedimentary_basin",
            "location_geology_context",
            "nearby_geological_faults",
            "nearby_tectonic_plates",
            "faults_average_seismic_activity_events_per_year",
            "fault_linked_relevant_events",
            "liquefaction_likelihood",
            "landslide_susceptibility",
            "distance_to_coast_or_rivers_km"
          ],
          "properties": {
            "soil_type": { "type": "string" },
            "lithology": { "type": "string" },
            "vs30_m_per_s": { "type": "number" },
            "slope_degrees": { "type": "number" },
            "sedimentary_basin": { "type": "string" },
            "location_geology_context": { "type": "string" },
            "nearby_geological_faults": {
              "type": "array",
              "items": { "type": "string" }
            },
            "nearby_tectonic_plates": {
              "type": "array",
              "items": { "type": "string" }
            },
            "faults_average_seismic_activity_events_per_year": { "type": "number" },
            "fault_linked_relevant_events": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["event_name", "event_year", "magnitude_mw", "linked_fault"],
                "properties": {
                  "event_name": { "type": "string" },
                  "event_year": { "type": "integer" },
                  "magnitude_mw": { "type": "number" },
                  "linked_fault": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            },
            "liquefaction_likelihood": { "type": "string" },
            "landslide_susceptibility": { "type": "string" },
            "distance_to_coast_or_rivers_km": { "type": "number" }
          }
        },
        "climatic": {
          "type": "object",
          "required": [
            "rainfall_7d_mm",
            "rainfall_15d_mm",
            "rainfall_30d_mm",
            "soil_moisture_index",
            "extreme_events",
            "terrain_saturation",
            "mass_movement_risk"
          ],
          "properties": {
            "rainfall_7d_mm": { "type": "number" },
            "rainfall_15d_mm": { "type": "number" },
            "rainfall_30d_mm": { "type": "number" },
            "soil_moisture_index": { "type": "number" },
            "extreme_events": { "type": "string" },
            "terrain_saturation": { "type": "string" },
            "mass_movement_risk": { "type": "string" }
          }
        },
        "human_urban": {
          "type": "object",
          "required": [
            "exposed_population",
            "urban_density",
            "building_type",
            "average_building_height_m",
            "construction_age_profile",
            "hospitals_count",
            "primary_roads_density_km_per_km2",
            "ports_airports_access",
            "schools_count",
            "critical_infrastructure"
          ],
          "properties": {
            "exposed_population": { "type": "integer" },
            "urban_density": { "type": "string" },
            "building_type": { "type": "string" },
            "average_building_height_m": { "type": "number" },
            "construction_age_profile": { "type": "string" },
            "hospitals_count": { "type": "integer" },
            "primary_roads_density_km_per_km2": { "type": "number" },
            "ports_airports_access": { "type": "string" },
            "schools_count": { "type": "integer" },
            "critical_infrastructure": { "type": "string" }
          }
        }
      }
    },
    "compound_risk_model": {
      "type": "object",
      "required": [
        "model_type",
        "component_scores",
        "risk_score_total",
        "risk_category",
        "derived_outputs"
      ],
      "properties": {
        "model_type": { "type": "string" },
        "component_scores": {
          "type": "object",
          "required": [
            "seismic_hazard",
            "human_exposure",
            "structural_vulnerability",
            "geotechnical_vulnerability",
            "climatic_conditions",
            "infrastructure_criticality"
          ],
          "properties": {
            "seismic_hazard": { "type": "number" },
            "human_exposure": { "type": "number" },
            "structural_vulnerability": { "type": "number" },
            "geotechnical_vulnerability": { "type": "number" },
            "climatic_conditions": { "type": "number" },
            "infrastructure_criticality": { "type": "number" }
          }
        },
        "component_weights": {
          "type": "object",
          "properties": {
            "seismic_hazard": { "type": "number" },
            "human_exposure": { "type": "number" },
            "structural_vulnerability": { "type": "number" },
            "geotechnical_vulnerability": { "type": "number" },
            "climatic_conditions": { "type": "number" },
            "infrastructure_criticality": { "type": "number" }
          }
        },
        "risk_score_total": { "type": "number" },
        "risk_category": {
          "type": "string",
          "enum": ["riesgo_bajo", "riesgo_medio", "riesgo_alto", "riesgo_critico"]
        },
        "derived_outputs": {
          "type": "object",
          "required": [
            "probability_strong_aftershock",
            "probability_structural_damage",
            "probability_landslide",
            "population_exposure_index",
            "relative_urban_collapse_index"
          ],
          "properties": {
            "probability_strong_aftershock": { "type": "number" },
            "probability_structural_damage": { "type": "number" },
            "probability_landslide": { "type": "number" },
            "population_exposure_index": { "type": "number" },
            "relative_urban_collapse_index": { "type": "number" }
          }
        }
      }
    }
  }
}

