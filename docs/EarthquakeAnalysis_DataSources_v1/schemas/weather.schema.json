{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Weather Reanalysis",
  "type": "object",
  "properties": {
    "source": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "time_utc": {
      "type": "string",
      "format": "date-time"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "variables": {
      "type": "object"
    }
  }
}
